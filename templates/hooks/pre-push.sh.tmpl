#!/usr/bin/env bash
# Pre-push payload: the fullest gate tier the project configures. Inert until
# wired into a hook setup you own — e.g. a .git/hooks/pre-push stub containing:
#   exec bash .awf/hooks/pre-push.sh "$@"
set -euo pipefail
{{ if not (or .vars.gateCmdFull .vars.gateCmd .vars.checkCmd) }}
# Run the pinned awf when the bootstrap resolves; fall back to PATH awf.
awf() { local pinned; if [ -f .awf/bootstrap.sh ] && pinned="$(bash .awf/bootstrap.sh 2>/dev/null)"; then "$pinned" "$@"; else command awf "$@"; fi; }
{{ end }}
{{- with .vars.gateCmdFull }}{{ . }}{{ else }}{{ with .vars.gateCmd }}{{ . }}{{ else }}{{ with .vars.checkCmd }}{{ . }}{{ else }}awf check{{ end }}{{ end }}{{ end }}
