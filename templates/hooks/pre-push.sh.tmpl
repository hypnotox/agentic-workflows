set -euo pipefail
{{ with .vars.gateCmdFull }}{{ . }}{{ else }}{{ with .vars.gateCmd }}{{ . }}{{ else }}{{ with .vars.checkCmd }}{{ . }}{{ else }}{{ if .runnerEnabled }}./awf{{ else }}awf{{ end }} check{{ end }}{{ end }}{{ end }}
