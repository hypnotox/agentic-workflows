#!/usr/bin/env bash
# Pre-commit payload: drift check, the staged current-state check, then the
# project gate. Inert until wired into a hook setup you own, e.g. a
# .git/hooks/pre-commit stub containing:
#   exec bash .awf/hooks/pre-commit.sh "$@"
set -euo pipefail
{{- with .vars.checkCmd }}
{{ . }}
{{ . }} --staged
{{- else }}
{{ if .runnerEnabled }}./awf{{ else }}awf{{ end }} check
{{ if .runnerEnabled }}./awf{{ else }}awf{{ end }} check --staged
{{- end }}
{{- with .vars.gateCmd }}
{{ . }}
{{- end }}
{{ with .vars.proseGateCmd }}{{ . }}{{ else }}{{ if .runnerEnabled }}./awf{{ else }}awf{{ end }} prose-gate{{ end }}
