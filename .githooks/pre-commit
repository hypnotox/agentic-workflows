#!/usr/bin/env bash
# Repo wiring for the rendered pre-commit payload, plus a repo-local staged-slice
# validation: concurrent sessions share this worktree's index, and a commit is a
# slice of the index while the payload below validates the worktree - a
# cross-session or partial-staging accident can therefore land a commit that, on
# its own, does not BUILD (bit the ADR-0088 session) or is DRIFT-inconsistent (a
# rendered/lock hunk left unstaged; bit commit a85bd6a - HEAD's `./x check`
# failed while the worktree was clean). Build AND drift-check the exact staged
# slice in a throwaway checkout so a non-hermetic or drifted commit refuses here.
set -euo pipefail
tmp=$(mktemp -d)
trap 'rm -rf "$tmp"' EXIT
git checkout-index --prefix="$tmp/" -a
# Hooks inherit GIT_DIR/GIT_WORK_TREE for the caller. Clear those before using
# Git inside the foreign temporary repository; later commands rediscover this
# linked worktree from its .git file.
unset $(git rev-parse --local-env-vars)
# Current-state checks read one Git snapshot. Give the exact staged slice its
# own temporary identity so both the root project and nested Sundial can resolve
# a HEAD without observing the caller's unstaged worktree.
git -C "$tmp" init -q
git -C "$tmp" add -f .
git -C "$tmp" -c core.hooksPath=/dev/null -c user.name=awf-hook -c user.email=awf-hook@localhost commit -q -m staged-slice
if ! (cd "$tmp" && go build ./... >/dev/null); then
  echo "pre-commit: the staged slice does not build on its own - a foreign or missing hunk is staged" >&2
  exit 1
fi
# Sanctioned current-state cutover boundary (Plan 4): when a verified external
# pinned bridge binary is supplied, drift-check the staged slice with it instead
# of the from-source binary, because the staged 0.19.0 runtime no longer renders
# the 0.18.0 bridge-era outputs. This branch is removed or made inert after
# cutover; the from-source path below is otherwise retained exactly.
if [ -n "${AWF_PREP_BRIDGE:-}" ] && [ -n "${AWF_PREP_BRIDGE_SHA256:-}" ]; then
  if ! printf '%s  %s\n' "$AWF_PREP_BRIDGE_SHA256" "$AWF_PREP_BRIDGE" | sha256sum -c - >/dev/null 2>&1; then
    echo "pre-commit: AWF_PREP_BRIDGE hash does not match AWF_PREP_BRIDGE_SHA256 - refusing an unverified bridge binary" >&2
    exit 1
  fi
  awf_slice="$AWF_PREP_BRIDGE"
  prep=1
else
  (cd "$tmp" && go build -o awf-slice ./cmd/awf)
  awf_slice="$tmp/awf-slice"
  prep=0
fi
# check_slice validates rendered-output drift in a slice directory. In the
# from-source path (prep=0) any non-zero check refuses. In the pinned-bridge prep
# path (prep=1) the 0.18.0 bridge's legacy invariant backing check cannot pass on
# a current-state-migrated tree (invariants: became currentState:, markers became
# qualified), so gate on the rendered-output drift count alone - which is what the
# pinned bridge validates here - and ignore its expected legacy-invariant lines.
check_slice() {
  dir="$1"; label="$2"
  if [ "$prep" = 0 ]; then
    if ! (cd "$dir" && "$awf_slice" check >/dev/null); then
      echo "pre-commit: the staged slice has drift in $label - run ./x sync and stage the result" >&2
      exit 1
    fi
    return 0
  fi
  rc=0
  out="$(cd "$dir" && "$awf_slice" check 2>&1)" || rc=$?
  [ "$rc" -eq 0 ] && return 0
  n="$(printf '%s\n' "$out" | sed -n 's/^awf: awf check: \([0-9][0-9]*\) drift.*/\1/p')"
  if [ -z "$n" ] || [ "$n" -ne 0 ]; then
    echo "pre-commit: the staged slice has rendered-output drift in $label (run the pinned bridge sync and stage the result):" >&2
    printf '%s\n' "$out" | grep -vE '^  invariant |^note:' >&2
    exit 1
  fi
}
check_slice "$tmp" "the repository"
# The example adopter is part of the slice too: a template/configspec hunk whose
# sundial re-render is left unstaged committed clean three times (a85bd6a, the
# ADR-0080 flip, the ADR-0121 phase 1) before this check existed.
check_slice "$tmp/examples/sundial" "examples/sundial"
# In the pinned-bridge preparation commit the rendered payload's `./x check` runs
# the staged 0.19.0 runtime against bridge-rendered outputs, which necessarily
# disagree until the final cutover sync; the pinned-bridge drift checks above are
# the authority here. The from-source path keeps the normal rendered payload.
if [ "$prep" != 1 ]; then
  exec bash .awf/hooks/pre-commit.sh "$@"
fi
