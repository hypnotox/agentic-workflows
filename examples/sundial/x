#!/usr/bin/env bash
# Command runner for the sundial repo - project verbs only; awf verbs go through ./awf.
set -euo pipefail

cmd="${1:-}"
shift || true

case "$cmd" in
  gate)
    # `full` is accepted for pre-push hook compatibility; no slower tier exists.
    go test ./...
    go vet ./... ;;
  test)
    go test ./... "$@" ;;
  *)
    echo "usage: ./x {gate|test}" >&2
    exit 1 ;;
esac
